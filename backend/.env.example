# Backend server
PORT=4000

# Optional API key: when set, clients must send `x-api-key`
# You can use either name (both are supported by backend/server.js)
API_KEY=
ESTIMATE_TOOL_API_KEY=

# SMTP settings (used by backend/send-db-email.js)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_TO=

