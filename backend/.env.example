# Backend server
PORT=4000
DB_PATH=

# Comma-separated frontend origins allowed by CORS.
# Example: https://switchgear-estimate-app.vercel.app,https://intranet.example.com
CORS_ORIGINS=
CORS_ALLOW_VERCEL=false

# Optional API key: when set, clients must send `x-api-key`
# You can use either name (both are supported by backend/server.js)
API_KEY=
ESTIMATE_TOOL_API_KEY=
# Default is to require API key. Set to "false" only for local dev.
REQUIRE_API_KEY=true

# Rate limit (enabled by default)
RATE_LIMIT_ENABLED=true

# Payload & validation limits (defense-in-depth)
JSON_BODY_LIMIT=1mb
MAX_STRING_LENGTH=10000
MAX_ARRAY_LENGTH=1000
MAX_BACKUP_ITEMS=5000
SANITIZE_DEPTH_LIMIT=6

# Project file attachments
# Leave empty to use backend/attachments. On NAS, point this to a persistent shared volume.
ATTACHMENT_STORAGE_PATH=
ATTACHMENT_MAX_FILE_SIZE=26214400

# SMTP settings (used by backend/send-db-email.js)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_TO=

#드롭박스 환경변수
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
DROPBOX_SHARED_LINK=https://www.dropbox.com/scl/fo/...
